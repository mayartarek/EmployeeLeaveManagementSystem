@model IEnumerable<EmployeeLeaveManagementSystem.Models.LeaveTypes>

@{
    ViewData["Title"] = "Index";
}

<h1>Index</h1>

<p>
    <a asp-action="Create">Create New</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.LeaveTypeName)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.MaximumDaysAllowed)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.LeaveRequests)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(model => item.LeaveTypeName)
            </td>
            <td>
                @Html.DisplayFor(model => item.MaximumDaysAllowed)
            </td>
            <td>
                @Html.DisplayFor(model => item.LeaveRequests)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.Id">Edit</a> |
                <a asp-action="Details" asp-route-id="@item.Id">Details</a> |
                <a asp-action="Delete" asp-route-id="@item.Id">Delete</a>
            </td>
        </tr>
}
    </tbody>
</table>
