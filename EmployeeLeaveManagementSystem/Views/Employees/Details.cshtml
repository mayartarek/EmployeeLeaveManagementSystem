@model EmployeeLeaveManagementSystem.Models.Employee

@{
    ViewData["Title"] = "Employee Details";
}

<h1>Employee Details</h1>

<div>
    <h4>Employee</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">Name</dt>
        <dd class = "col-sm-10">@Model.EmployeeName</dd>

        <dt class = "col-sm-2">Email</dt>
        <dd class = "col-sm-10">@Model.EmployeeEmail</dd>

        <dt class = "col-sm-2">Phone</dt>
        <dd class = "col-sm-10">@Model.EmployeePhone</dd>

        <dt class = "col-sm-2">Code</dt>
        <dd class = "col-sm-10">@Model.EmployeeCode</dd>

        <dt class = "col-sm-2">Department</dt>
        <dd class = "col-sm-10">@Model.EmployeeDepartment</dd>
    </dl>
</div>

<div>
    <a class="btn btn-secondary" asp-action="Index">Back to List</a>
    <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Id">Edit</a>
</div>
